# Secretos / credenciales
config/.env
config/elevenlabs_backup_code.txt
config/credentials.json
config/token.pickle
config/sheets_id.txt

# Datos generados (imagenes, reportes, metadata) - muy pesado para git
data/*
!data/catalogo.db
marketing_app/data/contenidos.db
marketing_app/data/generated_images/
marketing_app/data/generated_reels/
marketing_app/data/backups/

# Checkpoint de alertas Droppers (necesario en CI para no reprocesar el historial)
!data/droppers_alertas_estado.json

# Config de precios (necesaria para el calculo de precios en CI)
!data/precios
data/precios/*
!data/precios/config_precios_v2.json

# Config de zonas de envio (necesaria para el calculo de envios en la API)
!data/envios
data/envios/*
!data/envios/zonas_envio.json

# Metadata de productos (estado del pipeline, necesaria en CI)
# Se ignoran imagenes/subcarpetas, solo se versiona metadata.json
!data/productos
data/productos/*
!data/productos/*/
data/productos/*/*
!data/productos/*/metadata.json

# Logs
logs/

# Cache de informes HTML descargados
config/html_informes_files/
config/html_informes_droppers.html

# Python
__pycache__/
scripts/utils/__pycache__/
*.pyc
*.pyo

# Reportes temporales
reporte_*.json
debug_*.html
debug_*.txt

# OS
Thumbs.db
.DS_Store

# Claude Code (configuración local del entorno)
.claude/
